{
  "name": "getreceipts",
  "version": "0.1.0",
  "description": "Catch your AI coding agent claiming work it didn't do. Deterministic, read-only, zero-config. The lie detector for Claude Code.",
  "type": "module",
  "bin": {
    "getreceipts": "./dist/cli.js",
    "receipts": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "claude-code",
    "ai",
    "coding-agent",
    "hooks",
    "mcp",
    "verification",
    "hallucination",
    "ai-slop",
    "cursor"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  }
}
